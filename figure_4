# timeseries of TCs in climate regions

import pandas as pd
from pathlib import Path
import matplotlib.pyplot as plt
import pymannkendall as mk
from scipy.stats import pearsonr

base_dir = Path("/Users/dkalashnikov/Desktop/tc_precip")

region_name_map = {
    1: "NW",
    2: "W",
    3: "NR&P",
    4: "SW",
    5: "S",
    6: "UM",
    7: "OV",
    8: "SE",
    9: "NE",
}

natl_counts = natl_counts.values
epac_counts = epac_counts.values

fig, axes = plt.subplots(3, 3, figsize=(15, 10), sharex=True, sharey=True)
axes = axes.ravel()

for region_id in range(1, 10):
    csv_path = base_dir / f"all_tc_combined_{region_id}.csv"
    df = pd.read_csv(csv_path)

    df = df.dropna(subset=["SID"]).copy()

    # count unique SIDs per year
    counts = df.groupby("year")["SID"].nunique()

    year_index = pd.Index(
        range(1980, 2025),
        name="year",
    )
    counts = counts.reindex(year_index, fill_value=0)

    # MK test + Sen's slope
    mk_result = mk.original_test(counts.values)

    # Pearson correlations vs basin-total activity

    r_natl, p_natl = pearsonr(counts.values, natl_counts)
    r_epac, p_epac = pearsonr(counts.values, epac_counts)

    r_natl_star = "*" if p_natl < 0.05 else ""
    r_epac_star = "*" if p_epac < 0.05 else ""

    ax = axes[region_id - 1]
    ax.plot(counts.index, counts.values, color="orangered", linewidth=1.8)

    ax.set_title(region_name_map[region_id], fontsize=14)
    ax.set_ylabel("Number of TCs", fontsize=12)

    # UPDATED: y-axis lower bound = -1, ticks unchanged
    ax.set_ylim(-0.5, 10)
    ax.set_yticks([0, 2, 4, 6, 8, 10])

    ax.tick_params(axis="both", labelsize=10, labelbottom=True, labelleft=True)

    # text box 1: MK + Sen
    ax.text(
        0.02,
        0.96,
        f"slope = {mk_result.slope:.2g}\n"
        f"pval = {mk_result.p:.2f}",
        transform=ax.transAxes,
        fontsize=10,
        va="top",
        ha="left",
        bbox=dict(boxstyle="round,pad=0.2", facecolor="white", edgecolor="none", alpha=0.9),
    )

    # text box 2: Pearson r
    if region_id > 3: # don't plot for first 3 regions
        ax.text(
            0.34,
            0.98,
            r"$\mathrm{r}(\mathrm{TC}_{\mathrm{ALL}},\,\mathrm{TC}_{\mathrm{NATL}})$ = "
            + f"{r_natl:.2f}{r_natl_star}\n"
            r"$\mathrm{r}(\mathrm{TC}_{\mathrm{ALL}},\,\mathrm{TC}_{\mathrm{EPAC}})$ = "
            + f"{r_epac:.2f}{r_epac_star}",
            transform=ax.transAxes,
            fontsize=10,
            va="top",
            ha="left",
            bbox=dict(boxstyle="round,pad=0.2", facecolor="white", edgecolor="none", alpha=0.9),
        )

fig.subplots_adjust(wspace=0.35, hspace=0.45)
