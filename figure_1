# panel A

# make Milton plot

import geopandas as gpd
import matplotlib.pyplot as plt
import numpy as np

import cartopy.crs as ccrs
import cartopy.feature as cfeature
from cartopy.geodesic import Geodesic
from cartopy.mpl.ticker import LongitudeFormatter, LatitudeFormatter

from matplotlib.lines import Line2D

# -----------------------------
# Inputs
# -----------------------------
center_lat = 27.9619 # station lat
center_lon = -82.5403 # station lon
x_lat = 27.8 # tc lat
x_lon = -82.1 # tc lon
radius_km = 500
track_shp = "milton_2024.shp"

# -----------------------------
# Load track
# -----------------------------
track = gpd.read_file(track_shp)
if track.crs is None:
    track = track.set_crs("EPSG:4326")
else:
    track = track.to_crs("EPSG:4326")

# -----------------------------
# Build 500-km geodesic circle
# -----------------------------
circle_lonlat = Geodesic().circle(
    lon=x_lon,
    lat=x_lat,
    radius=radius_km * 1000,
    n_samples=360,
)

# -----------------------------
# Plot
# -----------------------------
proj = ccrs.PlateCarree()
fig = plt.figure(figsize=(11, 8))
ax = plt.axes(projection=proj)

# UPDATED extent (western bound = -90)
ax.set_extent([-90, -75, 22, 36], crs=proj)

# Boundaries
ax.add_feature(cfeature.BORDERS, edgecolor="black", linewidth=1.0, zorder=1)
ax.add_feature(cfeature.STATES, edgecolor="0.6", linewidth=0.8, zorder=1)

# 500 km radius
ax.plot(
    circle_lonlat[:, 0],
    circle_lonlat[:, 1],
    color="black",
    linewidth=2,
    transform=proj,
    zorder=3,
)

# Station (red dot)
ax.scatter(
    center_lon,
    center_lat,
    s=80,
    color="red",
    edgecolor="black",
    linewidth=1.0,
    transform=proj,
    zorder=5,
)

# Hurricane Milton track
track.plot(
    ax=ax,
    color="blue",
    linewidth=2,
    transform=proj,
    zorder=4,
)

# TC position (black X)
ax.scatter(
    x_lon,
    x_lat,
    marker="x",
    s=180,
    color="black",
    linewidth=2,
    transform=proj,
    zorder=6,
)

# Lat/lon ticks 
ax.set_xticks(np.arange(-90, -74.9, 5), crs=proj)
ax.set_yticks(np.arange(22, 35.1, 4), crs=proj)
ax.xaxis.set_major_formatter(LongitudeFormatter())
ax.yaxis.set_major_formatter(LatitudeFormatter())
ax.tick_params(labelsize=16)
#ax.set_title("Example of local TC matching", size=20)

# -----------------------------
# Legend (bottom left)
# -----------------------------
legend_elements = [
    Line2D([0], [0], marker="o", color="w", label="Station",
           markerfacecolor="red", markeredgecolor="black", markersize=8),
    Line2D([0], [0], marker="x", color="black", label="TC position",
           markersize=8, linewidth=0),
    Line2D([0], [0], color="blue", lw=2, label="TC track"),
    Line2D([0], [0], color="black", lw=2, label="TC radius"),
]

ax.legend(
    handles=legend_elements,
    loc="lower left",
    bbox_to_anchor=(-0.02, 0.07),  # (x, y) → increase y to move legend up
    fontsize=14,
    frameon=False,
)

plt.show()
plt.savefig('milton_case.pdf',dpi=600)

# panel B

# plot Milton on 10/10/2024 (TCWV, track, stations)

import xarray as xr
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

import geopandas as gpd
import cartopy.crs as ccrs
import cartopy.feature as cfeature
from cartopy.mpl.ticker import LongitudeFormatter, LatitudeFormatter
from matplotlib.colors import BoundaryNorm

# read CSVs
all_df = pd.read_csv("all_combined_tcs.csv")

# -----------------------------
# Load TCWV z-score dataset
# -----------------------------
ds = xr.open_dataset("tcwv_daily_z.nc")

# -----------------------------
# Load Z500 dataset + subset
# -----------------------------
ds_z500 = xr.open_dataset("z500_tc_2024.nc")

z500_sel = ds_z500["z"].sel(
    valid_time="2024-10-09",
    latitude=slice(36, 22),
    longitude=slice(270, 285)        # match -90 to -75 using 0–360 convention
).squeeze("pressure_level", drop=True)

# convert lon to -180..180 for plotting on this map, then sort
z500_sel = z500_sel.assign_coords(
    longitude=(((z500_sel.longitude + 180) % 360) - 180)
).sortby("longitude")

# Convert geopotential to geopotential height (meters)
z500_sel = z500_sel / 9.80665

# -----------------------------
# Subset data
# -----------------------------
tcwv_sel = ds["tcwv"].sel(
    valid_time="2024-10-09",
    latitude=slice(22, 36),          # 20–46°N
    longitude=slice(-90, -75)        # 95–60°W
)

milton_df = all_df[all_df["SID"] == "2024279N21265"].copy()

# convert precip from inches to mm
milton_df["precip_mm"] = milton_df["precip"] * 25.4

# make Milton stations GeoDataFrame
milton_gdf = gpd.GeoDataFrame(
    milton_df,
    geometry=gpd.points_from_xy(milton_df["LONGITUDE"], milton_df["LATITUDE"]),
    crs="EPSG:4326",
)

# sort ascending to make higher precip values plot on top (last)
milton_gdf = milton_gdf.sort_values("precip_mm")

# -----------------------------
# Read Milton 2024 track shapefile
# -----------------------------
track = gpd.read_file("milton_2024.shp")
if track.crs is None:
    track = track.set_crs("EPSG:4326")
else:
    track = track.to_crs("EPSG:4326")

# -----------------------------
# Plot (Cartopy)
# -----------------------------
fig = plt.figure(figsize=(9, 7))
ax = plt.axes(projection=ccrs.PlateCarree())

# Map extent
ax.set_extent([-90, -75, 22, 36], crs=ccrs.PlateCarree())

ax.coastlines(resolution="50m", linewidth=0.8)
ax.add_feature(cfeature.BORDERS, linewidth=0.5)
ax.add_feature(cfeature.STATES, linewidth=0.5)

# Latitude and longitude tick marks (every 5°)
ax.set_xticks(np.arange(-90, -74.9, 5), crs=ccrs.PlateCarree())
ax.set_yticks(np.arange(22, 35.1, 4), crs=ccrs.PlateCarree())
ax.xaxis.set_major_formatter(LongitudeFormatter())
ax.yaxis.set_major_formatter(LatitudeFormatter())
ax.tick_params(labelsize=14)

# Discrete bins every 0.25 from -3 to 3
bounds = np.arange(-4, 4.0 + 0.25, 0.25)
norm = BoundaryNorm(bounds, ncolors=plt.get_cmap("PRGn").N, clip=False)

pcm = ax.pcolormesh(
    tcwv_sel.longitude,
    tcwv_sel.latitude,
    tcwv_sel,
    cmap="PRGn",
    norm=norm,
    shading="auto",
    transform=ccrs.PlateCarree()
)

cs = ax.contour(
    z500_sel.longitude,
    z500_sel.latitude,
    z500_sel,
    levels=np.arange(5780, 5901, 20),
    colors="black",
    linewidths=1.2,
    transform=ccrs.PlateCarree(),
    zorder=6
)

ax.clabel(cs, fmt="%d", fontsize=12, inline=True)

# -----------------------------
# Horizontal colorbar (no label)
# -----------------------------
cbar = plt.colorbar(
    pcm,
    ax=ax,
    orientation="vertical",
    #extend="max",
    pad=0.08,
    boundaries=bounds,
    ticks=np.arange(-4, 4.0 + 0.5, 1),
    aspect=35
)
cbar.ax.tick_params(labelsize=18)

# Milton track
track.plot(
    ax=ax,
    transform=ccrs.PlateCarree(),
    color="blue",
    linewidth=3,
    zorder=5
)

# Station locations 
milton_gdf.plot(
    ax=ax,
    transform=ccrs.PlateCarree(),
    markersize=80,         
    color="gold",
    edgecolor="black",
    linewidth=0.8,
    zorder=10               # ensure on top of everything
)

#ax.set_title("WV std. anomalies on 10 OCT 2024", fontsize=18)

# -----------------------------
# Legend (bottom left)
# -----------------------------
legend_elements = [
    Line2D(
    [0], [0],
    marker="o",
    linestyle="None",          # <-- disables the line entirely
    label="Stations",
    markerfacecolor="gold",
    markeredgecolor="black",
    markersize=8
    ),
    Line2D(
        [0], [0],
        color="blue",
        lw=3,
        label="TC track"
    ),
    Line2D(
        [0], [0],
        color="black",
        lw=1.5,
        label="Z500 contours"
    ),
]

ax.legend(
    handles=legend_elements,
    #loc="upper left",
    bbox_to_anchor=(0.4, 0.92),
    fontsize=14,
    frameon=False,
)

plt.show()

